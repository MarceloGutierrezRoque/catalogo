  /api/payments/create-checkout-session/:
    post:
      operationId: payments_create_checkout_session_create
      tags:
      - payments
      requestBody:
        content:
          application/json:
            schema:
              $ref: '#/components/schemas/CreateCheckoutSession'
            examples:
              ValidRequest:
                value:
                  product_id: 1
                  quantity: 1
                  success_url: https://example.com/success
                  cancel_url: https://example.com/cancel
                  customer_email: buyer@example.com
                summary: Valid request
          application/x-www-form-urlencoded:
            schema:
              $ref: '#/components/schemas/CreateCheckoutSession'
          multipart/form-data:
            schema:
              $ref: '#/components/schemas/CreateCheckoutSession'
        required: true
      security:
      - jwtAuth: []
      - {}
      responses:
        '201':
          content:
            application/json:
              schema:
                $ref: '#/components/schemas/CheckoutSessionResponse'
              examples:
                ValidResponse:
                  value:
                    session_id: cs_test_a1b2c3d4
                    session_url: https://checkout.stripe.com/cs_test_a1b2c3d4
                  summary: Valid response
          description: ''
        '400':
          description: Invalid input or product not synced
        '404':
          description: Product not found or inactive
  /api/payments/webhook/:
    post:
      operationId: payments_webhook_create
      description: 'Handles Stripe webhook events. Requires a valid Stripe signature
        in the `Stripe-Signature` header. Currently handles: `checkout.session.completed`.'
      tags:
      - payments
      security:
      - jwtAuth: []
      - {}
      responses:
        '200':
          description: Webhook processed successfully
        '400':
          description: Invalid payload or signature
        '404':
          description: Payment session not found
