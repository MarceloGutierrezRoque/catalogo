components:
  schemas:
    CheckoutSessionResponse:
      type: object
      properties:
        session_id:
          type: string
        session_url:
          type: string
          format: uri
      required:
      - session_id
      - session_url
    CreateCheckoutSession:
      type: object
      properties:
        product_id:
          type: integer
        quantity:
          type: integer
          minimum: 1
          default: 1
        success_url:
          type: string
          format: uri
        cancel_url:
          type: string
          format: uri
        customer_email:
          type: string
          format: email
      required:
      - cancel_url
      - product_id
      - success_url
    CustomTokenObtainPair:
      type: object
      properties:
        username:
          type: string
          writeOnly: true
        password:
          type: string
          writeOnly: true
      required:
      - password
      - username
    Customer:
      type: object
      properties:
        id:
          type: integer
          readOnly: true
        is_active:
          type: boolean
        created_at:
          type: string
          format: date-time
          readOnly: true
        updated_at:
          type: string
          format: date-time
          readOnly: true
        name:
          type: string
          maxLength: 255
        customer_type:
          type: string
          maxLength: 20
        document_type:
          type: string
          nullable: true
          maxLength: 20
        document_number:
          type: string
          nullable: true
          maxLength: 50
        email:
          type: string
          format: email
          nullable: true
          maxLength: 254
        phone:
          type: string
          nullable: true
          maxLength: 20
        address:
          type: string
          nullable: true
        city:
          type: string
          nullable: true
          maxLength: 100
        country:
          type: string
          nullable: true
          maxLength: 100
      required:
      - created_at
      - customer_type
      - id
      - name
      - updated_at
    Driver:
      type: object
      properties:
        id:
          type: integer
          readOnly: true
        is_active:
          type: boolean
        created_at:
          type: string
          format: date-time
          readOnly: true
        updated_at:
          type: string
          format: date-time
          readOnly: true
        license_number:
          type: string
          maxLength: 50
        phone:
          type: string
          nullable: true
          maxLength: 20
        email:
          type: string
          format: email
          nullable: true
          maxLength: 254
        hire_date:
          type: string
          format: date
          nullable: true
        is_available:
          type: boolean
        user:
          type: integer
      required:
      - created_at
      - id
      - license_number
      - updated_at
      - user
    Group:
      type: object
      properties:
        id:
          type: integer
          readOnly: true
        name:
          type: string
          maxLength: 150
        permissions:
          type: array
          items:
            type: integer
      required:
      - id
      - name
    Me:
      type: object
      properties:
        id:
          type: integer
          readOnly: true
        username:
          type: string
          readOnly: true
          description: Required. 150 characters or fewer. Letters, digits and @/./+/-/_
            only.
        email:
          type: string
          format: email
          title: Email address
          maxLength: 254
        first_name:
          type: string
          maxLength: 150
        last_name:
          type: string
          maxLength: 150
        is_superuser:
          type: boolean
          readOnly: true
          title: Superuser status
          description: Designates that this user has all permissions without explicitly
            assigning them.
        is_staff:
          type: boolean
          readOnly: true
          title: Staff status
          description: Designates whether the user can log into this admin site.
        date_joined:
          type: string
          format: date-time
          readOnly: true
        last_login:
          type: string
          format: date-time
          readOnly: true
          nullable: true
      required:
      - date_joined
      - id
      - is_staff
      - is_superuser
      - last_login
      - username
    PatchedCustomer:
      type: object
      properties:
        id:
          type: integer
          readOnly: true
        is_active:
          type: boolean
        created_at:
          type: string
          format: date-time
          readOnly: true
        updated_at:
          type: string
          format: date-time
          readOnly: true
        name:
          type: string
          maxLength: 255
        customer_type:
          type: string
          maxLength: 20
        document_type:
          type: string
          nullable: true
          maxLength: 20
        document_number:
          type: string
          nullable: true
          maxLength: 50
        email:
          type: string
          format: email
          nullable: true
          maxLength: 254
        phone:
          type: string
          nullable: true
          maxLength: 20
        address:
          type: string
          nullable: true
        city:
          type: string
          nullable: true
          maxLength: 100
        country:
          type: string
          nullable: true
          maxLength: 100
    PatchedDriver:
      type: object
      properties:
        id:
          type: integer
