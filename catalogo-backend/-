openapi: 3.0.3
info:
  title: Catálogo de Peluches API
  version: 1.0.0
  description: API RESTful para catálogo y gestión de pedidos de peluches.
paths:
  /api/admin/orders/:
    get:
      operationId: admin_orders_list
      description: Devuelve todos los pedidos sin items anidados.
      summary: Listar pedidos (admin)
      parameters:
      - name: ordering
        required: false
        in: query
        description: Which field to use when ordering the results.
        schema:
          type: string
      - name: page
        required: false
        in: query
        description: A page number within the paginated result set.
        schema:
          type: integer
      - name: search
        required: false
        in: query
        description: A search term.
        schema:
          type: string
      tags:
      - Órdenes (Admin)
      security:
      - jwtAuth: []
      - Bearer:
          type: http
          scheme: bearer
          bearerFormat: JWT
      responses:
        '200':
          content:
            application/json:
              schema:
                $ref: '#/components/schemas/PaginatedOrderAdminListList'
          description: ''
  /api/admin/orders/{id}/:
    get:
      operationId: admin_orders_retrieve
      description: Devuelve el pedido completo con sus items anidados.
      summary: Detalle de pedido con items
      parameters:
      - in: path
        name: id
        schema:
          type: integer
        description: A unique integer value identifying this order.
        required: true
      tags:
      - Órdenes (Admin)
      security:
      - jwtAuth: []
      - Bearer:
          type: http
          scheme: bearer
          bearerFormat: JWT
      responses:
        '200':
          content:
            application/json:
              schema:
                $ref: '#/components/schemas/OrderAdminDetail'
          description: ''
    patch:
      operationId: admin_orders_partial_update
      description: 'Actualiza solo el estado del pedido. Transiciones válidas: pending
        → contacted, contacted → closed | cancelled. Estados terminales (closed, cancelled)
        no permiten más cambios.'
      summary: Actualizar estado del pedido
      parameters:
      - in: path
        name: id
        schema:
          type: integer
        description: A unique integer value identifying this order.
        required: true
      tags:
      - Órdenes (Admin)
      requestBody:
        content:
          application/json:
            schema:
              $ref: '#/components/schemas/PatchedOrderStatusUpdate'
          application/x-www-form-urlencoded:
            schema:
              $ref: '#/components/schemas/PatchedOrderStatusUpdate'
          multipart/form-data:
            schema:
              $ref: '#/components/schemas/PatchedOrderStatusUpdate'
      security:
      - jwtAuth: []
      - Bearer:
          type: http
          scheme: bearer
          bearerFormat: JWT
      responses:
        '200':
          content:
            application/json:
              schema:
                $ref: '#/components/schemas/OrderAdminDetail'
          description: ''
  /api/admin/plushies/:
    get:
      operationId: admin_plushies_list
      description: Incluye inactivos y eliminados. Solo admin.
      summary: Listar todos los peluches
      parameters:
      - name: ordering
        required: false
        in: query
        description: Which field to use when ordering the results.
        schema:
          type: string
      - name: page
        required: false
        in: query
        description: A page number within the paginated result set.
        schema:
          type: integer
      - name: search
        required: false
        in: query
        description: A search term.
        schema:
          type: string
      tags:
      - Plushies (Admin)
      security:
      - jwtAuth: []
      - Bearer:
          type: http
          scheme: bearer
          bearerFormat: JWT
      responses:
        '200':
          content:
            application/json:
              schema:
                $ref: '#/components/schemas/PaginatedPlushieAdminList'
          description: ''
    post:
      operationId: admin_plushies_create
      summary: Crear peluche
      tags:
      - Plushies (Admin)
      requestBody:
        content:
          application/json:
            schema:
              $ref: '#/components/schemas/PlushieAdmin'
          application/x-www-form-urlencoded:
            schema:
              $ref: '#/components/schemas/PlushieAdmin'
          multipart/form-data:
            schema:
              $ref: '#/components/schemas/PlushieAdmin'
        required: true
      security:
      - jwtAuth: []
      - Bearer:
          type: http
          scheme: bearer
          bearerFormat: JWT
      responses:
        '201':
          content:
            application/json:
              schema:
                $ref: '#/components/schemas/PlushieAdmin'
          description: ''
  /api/admin/plushies/{id}/:
    get:
      operationId: admin_plushies_retrieve
      summary: Detalle de peluche (admin)
      parameters:
      - in: path
        name: id
        schema:
          type: integer
        description: A unique integer value identifying this plushie.
        required: true
      tags:
      - Plushies (Admin)
      security:
      - jwtAuth: []
      - Bearer:
          type: http
          scheme: bearer
          bearerFormat: JWT
      responses:
        '200':
          content:
            application/json:
              schema:
                $ref: '#/components/schemas/PlushieAdmin'
          description: ''
    put:
      operationId: admin_plushies_update
      summary: Actualizar peluche completo
      parameters:
      - in: path
        name: id
        schema:
          type: integer
        description: A unique integer value identifying this plushie.
        required: true
      tags:
      - Plushies (Admin)
      requestBody:
        content:
          application/json:
            schema:
              $ref: '#/components/schemas/PlushieAdmin'
          application/x-www-form-urlencoded:
            schema:
              $ref: '#/components/schemas/PlushieAdmin'
          multipart/form-data:
            schema:
              $ref: '#/components/schemas/PlushieAdmin'
        required: true
      security:
      - jwtAuth: []
      - Bearer:
          type: http
          scheme: bearer
          bearerFormat: JWT
      responses:
        '200':
          content:
            application/json:
              schema:
                $ref: '#/components/schemas/PlushieAdmin'
          description: ''
    patch:
      operationId: admin_plushies_partial_update
      summary: Actualizar peluche parcialmente
      parameters:
      - in: path
        name: id
        schema:
          type: integer
        description: A unique integer value identifying this plushie.
        required: true
      tags:
      - Plushies (Admin)
      requestBody:
        content:
          application/json:
            schema:
              $ref: '#/components/schemas/PatchedPlushieAdmin'
          application/x-www-form-urlencoded:
            schema:
              $ref: '#/components/schemas/PatchedPlushieAdmin'
          multipart/form-data:
            schema:
              $ref: '#/components/schemas/PatchedPlushieAdmin'
      security:
      - jwtAuth: []
      - Bearer:
          type: http
          scheme: bearer
          bearerFormat: JWT
      responses:
        '200':
          content:
            application/json:
              schema:
                $ref: '#/components/schemas/PlushieAdmin'
          description: ''
    delete:
      operationId: admin_plushies_destroy
      description: Marca is_deleted=True. No elimina físicamente.
      summary: Eliminar peluche (soft-delete)
      parameters:
      - in: path
        name: id
        schema:
          type: integer
        description: A unique integer value identifying this plushie.
        required: true
      tags:
      - Plushies (Admin)
      security:
      - jwtAuth: []
      - Bearer:
          type: http
          scheme: bearer
          bearerFormat: JWT
      responses:
        '204':
          description: No response body
  /api/admin/plushies/{id}/activate/:
    patch:
      operationId: admin_plushies_activate_partial_update
      description: Cambia is_active a True. El peluche vuelve al catálogo público.
      summary: Activar peluche
      parameters:
      - in: path
        name: id
        schema:
          type: integer
        description: A unique integer value identifying this plushie.
        required: true
      tags:
      - Plushies (Admin)
      security:
      - jwtAuth: []
      - Bearer:
          type: http
          scheme: bearer
          bearerFormat: JWT
      responses:
        '200':
          content:
            application/json:
              schema:
                type: object
                properties:
                  status:
                    type: string
          description: ''
  /api/admin/plushies/{id}/deactivate/:
    patch:
      operationId: admin_plushies_deactivate_partial_update
      description: Cambia is_active a False. El peluche se oculta del catálogo público.
      summary: Desactivar peluche
      parameters:
      - in: path
        name: id
        schema:
          type: integer
        description: A unique integer value identifying this plushie.
        required: true
      tags:
      - Plushies (Admin)
      security:
      - jwtAuth: []
      - Bearer:
          type: http
          scheme: bearer
          bearerFormat: JWT
      responses:
        '200':
          content:
            application/json:
              schema:
                type: object
                properties:
                  status:
                    type: string
          description: ''
  /api/dashboard/:
    get:
      operationId: dashboard_retrieve
      description: Resumen de pedidos agrupados por estado y conteo de peluches activos/inactivos.
        Solo accesible por administradores autenticados.
      summary: Dashboard — estadísticas
      tags:
      - Dashboard (Admin)
      security:
      - jwtAuth: []
      - Bearer:
          type: http
          scheme: bearer
          bearerFormat: JWT
      responses:
        '200':
          content:
            application/json:
              schema:
                $ref: '#/components/schemas/Dashboard'
          description: ''
  /api/orders/:
    post:
      operationId: orders_create
      description: Crea un nuevo pedido con items anidados. El precio de cada item
        se congela al valor actual del peluche. No requiere autenticación. Valida
        stock disponible y que el peluche esté activo.
      summary: Crear pedido (público)
      tags:
      - Órdenes (Público)
      requestBody:
        content:
          application/json:
            schema:
              $ref: '#/components/schemas/OrderCreate'
          application/x-www-form-urlencoded:
            schema:
              $ref: '#/components/schemas/OrderCreate'
          multipart/form-data:
            schema:
              $ref: '#/components/schemas/OrderCreate'
        required: true
      security:
      - jwtAuth: []
      - Bearer:
          type: http
          scheme: bearer
          bearerFormat: JWT
      - {}
      responses:
        '201':
          content:
            application/json:
              schema:
                $ref: '#/components/schemas/OrderCreate'
          description: ''
  /api/plushies/:
    get:
      operationId: plushies_list
      description: Devuelve solo peluches con is_active=True y is_deleted=False.
      summary: Listar peluches activos
      parameters:
      - name: ordering
        required: false
        in: query
        description: Which field to use when ordering the results.
        schema:
          type: string
      - name: page
        required: false
        in: query
        description: A page number within the paginated result set.
        schema:
          type: integer
      - name: search
        required: false
        in: query
        description: A search term.
        schema:
          type: string
      tags:
      - Catálogo (Público)
      security:
      - jwtAuth: []
      - Bearer:
          type: http
          scheme: bearer
          bearerFormat: JWT
      - {}
      responses:
        '200':
          content:
            application/json:
              schema:
                $ref: '#/components/schemas/PaginatedPlushiePublicList'
          description: ''
  /api/plushies/{id}/:
    get:
      operationId: plushies_retrieve
      description: Obtiene un peluche individual por ID.
      summary: Detalle de peluche
      parameters:
      - in: path
        name: id
        schema:
          type: integer
        description: A unique integer value identifying this plushie.
        required: true
      tags:
      - Catálogo (Público)
      security:
      - jwtAuth: []
      - Bearer:
          type: http
          scheme: bearer
          bearerFormat: JWT
      - {}
      responses:
        '200':
          content:
            application/json:
              schema:
                $ref: '#/components/schemas/PlushiePublic'
          description: ''
  /api/token/:
    post:
      operationId: token_create
      description: |-
        Takes a set of user credentials and returns an access and refresh JSON web
        token pair to prove the authentication of those credentials.
      tags:
      - token
      requestBody:
        content:
          application/json:
            schema:
              $ref: '#/components/schemas/TokenObtainPair'
          application/x-www-form-urlencoded:
            schema:
              $ref: '#/components/schemas/TokenObtainPair'
          multipart/form-data:
            schema:
              $ref: '#/components/schemas/TokenObtainPair'
        required: true
      security:
      - Bearer:
          type: http
          scheme: bearer
          bearerFormat: JWT
      responses:
        '200':
          content:
            application/json:
              schema:
                $ref: '#/components/schemas/TokenObtainPair'
          description: ''
  /api/token/refresh/:
    post:
      operationId: token_refresh_create
      description: |-
        Takes a refresh type JSON web token and returns an access type JSON web
        token if the refresh token is valid.
      tags:
      - token
      requestBody:
        content:
          application/json:
            schema:
              $ref: '#/components/schemas/TokenRefresh'
          application/x-www-form-urlencoded:
            schema:
              $ref: '#/components/schemas/TokenRefresh'
          multipart/form-data:
            schema:
              $ref: '#/components/schemas/TokenRefresh'
        required: true
      security:
      - Bearer:
          type: http
          scheme: bearer
          bearerFormat: JWT
      responses:
        '200':
          content:
            application/json:
              schema:
                $ref: '#/components/schemas/TokenRefresh'
          description: ''
  /api/users/:
    get:
      operationId: users_list
      summary: Listar administradores
      parameters:
      - name: ordering
        required: false
        in: query
        description: Which field to use when ordering the results.
        schema:
          type: string
      - name: page
        required: false
        in: query
        description: A page number within the paginated result set.
        schema:
          type: integer
      - name: search
        required: false
        in: query
        description: A search term.
        schema:
          type: string
      tags:
      - Usuarios (Admin)
      security:
      - jwtAuth: []
      - Bearer:
          type: http
          scheme: bearer
          bearerFormat: JWT
      responses:
        '200':
          content:
            application/json:
              schema:
                $ref: '#/components/schemas/PaginatedUserList'
          description: ''
    post:
      operationId: users_create
      description: Crea un nuevo usuario administrador. El password se hashea automáticamente.
      summary: Crear administrador
      tags:
      - Usuarios (Admin)
      requestBody:
        content:
          application/json:
            schema:
              $ref: '#/components/schemas/User'
          application/x-www-form-urlencoded:
            schema:
              $ref: '#/components/schemas/User'
          multipart/form-data:
            schema:
              $ref: '#/components/schemas/User'
        required: true
      security:
      - jwtAuth: []
      - Bearer:
          type: http
          scheme: bearer
          bearerFormat: JWT
      responses:
        '201':
          content:
            application/json:
              schema:
                $ref: '#/components/schemas/User'
          description: ''
  /api/users/{id}/:
    get:
      operationId: users_retrieve
      summary: Detalle de administrador
      parameters:
      - in: path
        name: id
        schema:
          type: integer
        description: A unique integer value identifying this user.
        required: true
      tags:
      - Usuarios (Admin)
      security:
      - jwtAuth: []
      - Bearer:
          type: http
          scheme: bearer
          bearerFormat: JWT
      responses:
        '200':
          content:
            application/json:
              schema:
                $ref: '#/components/schemas/User'
          description: ''
    put:
      operationId: users_update
      summary: Actualizar administrador completo
      parameters:
      - in: path
        name: id
        schema:
          type: integer
        description: A unique integer value identifying this user.
        required: true
      tags:
      - Usuarios (Admin)
      requestBody:
        content:
          application/json:
            schema:
              $ref: '#/components/schemas/User'
          application/x-www-form-urlencoded:
            schema:
              $ref: '#/components/schemas/User'
          multipart/form-data:
            schema:
              $ref: '#/components/schemas/User'
        required: true
      security:
      - jwtAuth: []
      - Bearer:
          type: http
          scheme: bearer
          bearerFormat: JWT
      responses:
        '200':
          content:
            application/json:
              schema:
                $ref: '#/components/schemas/User'
          description: ''
    patch:
      operationId: users_partial_update
      summary: Actualizar administrador parcialmente
      parameters:
      - in: path
        name: id
        schema:
          type: integer
        description: A unique integer value identifying this user.
        required: true
      tags:
      - Usuarios (Admin)
      requestBody:
        content:
          application/json:
            schema:
              $ref: '#/components/schemas/PatchedUser'
          application/x-www-form-urlencoded:
            schema:
              $ref: '#/components/schemas/PatchedUser'
          multipart/form-data:
            schema:
              $ref: '#/components/schemas/PatchedUser'
      security:
      - jwtAuth: []
      - Bearer:
          type: http
          scheme: bearer
          bearerFormat: JWT
      responses:
        '200':
          content:
            application/json:
              schema:
                $ref: '#/components/schemas/User'
          description: ''
    delete:
      operationId: users_destroy
      description: 'Soft-delete: marca is_active=False en lugar de eliminar.'
      summary: Desactivar administrador
      parameters:
      - in: path
        name: id
        schema:
          type: integer
        description: A unique integer value identifying this user.
        required: true
      tags:
      - Usuarios (Admin)
      security:
      - jwtAuth: []
      - Bearer:
          type: http
          scheme: bearer
          bearerFormat: JWT
      responses:
        '204':
          description: No response body
components:
  schemas:
    Dashboard:
      type: object
      properties:
        orders:
          allOf:
          - $ref: '#/components/schemas/DashboardOrderStats'
          readOnly: true
        plushies:
          allOf:
          - $ref: '#/components/schemas/DashboardPlushieStats'
          readOnly: true
      required:
      - orders
      - plushies
    DashboardOrderStats:
      type: object
      properties:
        pending:
          type: integer
          readOnly: true
        contacted:
          type: integer
          readOnly: true
        closed:
          type: integer
          readOnly: true
        cancelled:
          type: integer
          readOnly: true
        total:
          type: integer
          readOnly: true
      required:
      - cancelled
      - closed
      - contacted
      - pending
      - total
    DashboardPlushieStats:
      type: object
      properties:
        active:
          type: integer
          readOnly: true
        inactive:
          type: integer
          readOnly: true
        total:
          type: integer
          readOnly: true
      required:
      - active
      - inactive
      - total
    OrderAdminDetail:
      type: object
      description: Serializer admin — detalle de pedido con items anidados.
      properties:
        id:
          type: integer
          readOnly: true
        customer_name:
          type: string
          readOnly: true
        customer_email:
          type: string
          format: email
          readOnly: true
        customer_phone:
          type: string
          readOnly: true
        observations:
          type: string
          readOnly: true
          nullable: true
        status:
          $ref: '#/components/schemas/StatusEnum'
        items:
          type: array
          items:
            $ref: '#/components/schemas/OrderItem'
          readOnly: true
        created_at:
          type: string
          format: date-time
          readOnly: true
        updated_at:
          type: string
          format: date-time
          readOnly: true
      required:
      - created_at
      - customer_email
      - customer_name
      - customer_phone
      - id
      - items
      - observations
      - updated_at
    OrderAdminList:
      type: object
      description: Serializer admin — lista de pedidos (sin items anidados).
      properties:
        id:
          type: integer
          readOnly: true
        customer_name:
          type: string
          readOnly: true
        customer_email:
          type: string
          format: email
          readOnly: true
        customer_phone:
          type: string
          readOnly: true
        observations:
          type: string
          readOnly: true
          nullable: true
        status:
          $ref: '#/components/schemas/StatusEnum'
        created_at:
          type: string
          format: date-time
          readOnly: true
        updated_at:
          type: string
          format: date-time
          readOnly: true
      required:
      - created_at
      - customer_email
      - customer_name
      - customer_phone
      - id
      - observations
      - updated_at
    OrderCreate:
      type: object
      description: Serializer público — solo creación de orden con items anidados.
      properties:
        id:
          type: integer
          readOnly: true
        customer_name:
          type: string
          maxLength: 200
        customer_email:
          type: string
          format: email
          maxLength: 254
        customer_phone:
          type: string
          maxLength: 20
        observations:
          type: string
          nullable: true
        status:
          allOf:
          - $ref: '#/components/schemas/StatusEnum'
          readOnly: true
        items:
          type: array
          items:
            $ref: '#/components/schemas/OrderItem'
        created_at:
          type: string
          format: date-time
          readOnly: true
      required:
      - created_at
      - customer_email
      - customer_name
      - customer_phone
      - id
      - items
      - status
    OrderItem:
      type: object
      properties:
        id:
          type: integer
          readOnly: true
        plushie_id:
          type: integer
          writeOnly: true
        plushie_name:
          type: string
          readOnly: true
        quantity:
          type: integer
          maximum: 9223372036854775807
          minimum: 0
          format: int64
        unit_price:
          type: string
          format: decimal
          pattern: ^-?\d{0,8}(?:\.\d{0,2})?$
          readOnly: true
      required:
      - id
      - plushie_id
      - plushie_name
      - quantity
      - unit_price
    PaginatedOrderAdminListList:
      type: object
      required:
      - count
      - results
      properties:
        count:
          type: integer
          example: 123
        next:
          type: string
          nullable: true
          format: uri
          example: http://api.example.org/accounts/?page=4
        previous:
          type: string
          nullable: true
          format: uri
          example: http://api.example.org/accounts/?page=2
        results:
          type: array
          items:
            $ref: '#/components/schemas/OrderAdminList'
    PaginatedPlushieAdminList:
      type: object
      required:
      - count
      - results
      properties:
        count:
          type: integer
          example: 123
        next:
          type: string
          nullable: true
          format: uri
          example: http://api.example.org/accounts/?page=4
        previous:
          type: string
          nullable: true
          format: uri
          example: http://api.example.org/accounts/?page=2
        results:
          type: array
          items:
            $ref: '#/components/schemas/PlushieAdmin'
    PaginatedPlushiePublicList:
      type: object
      required:
      - count
      - results
      properties:
        count:
          type: integer
          example: 123
        next:
          type: string
          nullable: true
          format: uri
          example: http://api.example.org/accounts/?page=4
        previous:
          type: string
          nullable: true
          format: uri
          example: http://api.example.org/accounts/?page=2
        results:
          type: array
          items:
            $ref: '#/components/schemas/PlushiePublic'
    PaginatedUserList:
      type: object
      required:
      - count
      - results
      properties:
        count:
          type: integer
          example: 123
        next:
          type: string
          nullable: true
          format: uri
          example: http://api.example.org/accounts/?page=4
        previous:
          type: string
          nullable: true
          format: uri
